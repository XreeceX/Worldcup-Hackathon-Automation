# Postgres (docker-compose at repo root exposes it on host port 5433,
# because 5432 was already taken on this machine)
DATABASE_URL=postgres://commitment:commitment@localhost:5433/commitment

# Query API port
PORT=3002

# Solana
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
PROGRAM_ID=3uyiF93zMvUcP2o1Cqnt2iS4bXwYeBcTMTvbaTf5B3RJ

# Anchor IDL produced by `anchor build` in program/
IDL_PATH=../program/target/idl/commitment.json

# TxLINE credentials — optional. If unset, the loader falls back to
# ~/.secrets/txline-devnet-creds.json (fields: jwt, apiToken); if that is
# also missing, the indexer boots with an empty fixtures table.
TXLINE_JWT=
TXLINE_API_TOKEN=

# Browser origins allowed to call this API (comma-separated, or *).
# After Vercel deploy, set to your Vercel URL, e.g.:
# CORS_ORIGIN=http://localhost:3000,https://your-app.vercel.app
CORS_ORIGIN=http://localhost:3000
