# Keeper (all optional — sane defaults in keeper/index.mjs)
PORT=3001                      # keeper HTTP port
POLL_INTERVAL_MS=30000         # score polling fallback interval
REPLAY_FIXTURE_ID=18241006     # set to enable replay mode (England vs Argentina semi)

# Web (web/.env.local)
NEXT_PUBLIC_KEEPER_URL=http://localhost:3001
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# Secrets live in _keys/ (gitignored), created by scripts/connect.mjs:
#   _keys/wallet.json           keeper/resolver wallet
#   _keys/txline-session.json   subscribe txSig + activated API token
