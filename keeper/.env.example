# Keeper environment (design-01.md §7.1). Copy to .env or export in shell.
# NO real secrets in this file.

# --- required ---
ANCHOR_WALLET=./resolver-keypair.json            # path to resolver keypair JSON
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
ESCROW_MODE=on-chain
PROGRAM_ID=3uyiF93zMvUcP2o1Cqnt2iS4bXwYeBcTMTvbaTf5B3RJ
INDEXER_URL=http://localhost:3002

# Required, but if unset they are read from ~/.secrets/txline-devnet-creds.json
# (fields "jwt" / "apiToken", produced by txline-setup/setup.mjs).
TXLINE_JWT=
TXLINE_API_TOKEN=

# --- optional ---
PORT=3001                                        # keeper HTTP port
POLL_INTERVAL_MS=30000                           # score/fixture poll interval
REPLAY_FIXTURE_ID=                               # set to replay a historical fixture (demo mode)
IDL_PATH=../program/target/idl/commitment.json   # Anchor IDL of the Commitment program

# Browser origins allowed to call this API (comma-separated, or *).
# After Vercel deploy, set to your Vercel URL, e.g.:
# CORS_ORIGIN=http://localhost:3000,https://your-app.vercel.app
CORS_ORIGIN=http://localhost:3000
